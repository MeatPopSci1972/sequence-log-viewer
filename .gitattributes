# =================================================================
# sequence-log-viewer — .gitattributes
# Enforce LF everywhere, protect binaries, clean up diffs/archives
# =================================================================

# Default: auto-detect text, normalise to LF on commit + checkout
* text=auto eol=lf

# ── Source files ──────────────────────────────────────────────
*.html      text eol=lf diff=html
*.js        text eol=lf
*.json      text eol=lf diff=json
*.md        text eol=lf diff=markdown
*.txt       text eol=lf
*.properties text eol=lf

# ── Config / tooling ─────────────────────────────────────────
.gitattributes text eol=lf
.gitignore     text eol=lf

# ── Binary — never diff, never mangle line endings ───────────
*.png    binary
*.jpg    binary
*.jpeg   binary
*.gif    binary
*.ico    binary
*.woff   binary
*.woff2  binary
*.ttf    binary
*.eot    binary
*.zip    binary

# ── Export-ignore — excluded from git archive / release zips ─
.gitattributes  export-ignore
.gitignore      export-ignore
*-test.html     export-ignore
*.test.html     export-ignore
